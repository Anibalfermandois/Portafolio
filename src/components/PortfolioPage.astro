---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hero from "./Hero.astro";
import Experience from "./Experience.astro";
import Projects from "./Projects.astro";
import { technologies } from "../content/portfolio";
import type { Locale } from "../i18n/config";
import { ui } from "../i18n/ui";

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const copy = ui[locale];
const personalInfoEntry = await getEntry("personal", `${locale}/info`);
if (!personalInfoEntry)
    throw new Error(`Missing ${locale} personal info entry`);
const personalInfo = personalInfoEntry.data;
const allTechnologies = [
    ...technologies.languages,
    ...technologies.frameworks,
    ...technologies.infrastructure,
];
---

<Layout
    title={copy.pageTitle}
    description={copy.pageDescription}
    locale={locale}
>
    <div
        class="relative z-10 min-h-screen bg-transparent font-geist text-slate-900 selection:bg-blue-100 selection:text-blue-900"
    >
        <Hero locale={locale} />
        <Experience locale={locale} />
        <Projects locale={locale} />

        <section
            class="overflow-hidden border-t border-slate-100 bg-slate-50 px-6 py-16 reveal"
        >
            <div class="mx-auto mb-8 max-w-5xl text-center">
                <div
                    class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400"
                >
                    {copy.stack.eyebrow}
                </div>
                <h2
                    class="mb-12 flex items-center gap-4 text-3xl font-black text-slate-900"
                >
                    {copy.stack.title}
                </h2>
            </div>

            <div class="group relative flex overflow-x-hidden">
                <div
                    class="flex animate-marquee items-center gap-12 whitespace-nowrap py-4"
                >
                    {
                        allTechnologies.map((tech) => (
                            <div class="flex cursor-default items-center gap-3 px-4 text-slate-400 grayscale transition-all duration-300 hover:text-blue-600 hover:grayscale-0">
                                <img
                                    src={`https://cdn.simpleicons.org/${tech.icon}/64748b`}
                                    class="h-6 w-6 opacity-70 transition-opacity group-hover:opacity-100"
                                    alt=""
                                />
                                <span class="text-lg font-medium">
                                    {tech.name}
                                </span>
                            </div>
                        ))
                    }
                </div>
                <div
                    class="absolute top-0 flex animate-marquee2 items-center gap-12 whitespace-nowrap py-4"
                    aria-hidden="true"
                >
                    {
                        allTechnologies.map((tech) => (
                            <div class="flex cursor-default items-center gap-3 px-4 text-slate-400 grayscale transition-all duration-300 hover:text-blue-600 hover:grayscale-0">
                                <img
                                    src={`https://cdn.simpleicons.org/${tech.icon}/64748b`}
                                    class="h-6 w-6 opacity-70 transition-opacity group-hover:opacity-100"
                                    alt=""
                                />
                                <span class="text-lg font-medium">
                                    {tech.name}
                                </span>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <footer class="mt-12 bg-slate-900 px-6 py-20 text-slate-400">
            <div
                class="mx-auto grid max-w-5xl grid-cols-1 items-start gap-12 md:grid-cols-2"
            >
                <div class="reveal">
                    <h2
                        class="mb-6 text-5xl font-black tracking-tighter md:text-7xl"
                    >
                        {copy.footer.titleBefore}
                        <span class="text-blue-400 italic">
                            {copy.footer.titleAccent}
                        </span>
                    </h2>
                    <p class="mb-6 text-lg text-slate-300">
                        {copy.footer.description}
                    </p>
                </div>
                <div
                    class="flex flex-col gap-8 reveal reveal-stagger-1 md:items-end"
                >
                    <div class="flex items-center gap-6">
                        <a
                            href={personalInfo.linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-slate-400 transition-all hover:scale-110 hover:text-white"
                            aria-label={copy.footer.linkedInLabel}
                        >
                            <svg
                                class="h-8 w-8 fill-current"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                                ></path></svg
                            >
                        </a>
                        <a
                            href="https://github.com/Anibalfermandois"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-slate-400 transition-all hover:scale-110 hover:text-white"
                            aria-label={copy.footer.githubLabel}
                        >
                            <svg
                                class="h-8 w-8 fill-current"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                                ></path></svg
                            >
                        </a>
                    </div>
                    <a
                        href={`mailto:${personalInfo.contact}`}
                        class="rounded-xl bg-blue-600 px-8 py-4 text-lg font-bold text-white shadow-lg transition-all hover:-translate-y-1 hover:bg-blue-500 hover:shadow-blue-500/25"
                    >
                        {copy.footer.action}
                    </a>
                </div>
            </div>
            <div
                class="mx-auto mt-12 flex max-w-5xl flex-col items-center justify-between gap-4 border-t border-slate-800/50 pt-12 text-xs font-medium uppercase tracking-widest text-slate-600 md:flex-row"
            >
                <p>© {new Date().getFullYear()} Aníbal Fermandois</p>
            </div>
        </footer>
    </div>
</Layout>
