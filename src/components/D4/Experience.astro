---
import { experiences } from "../../data/portfolio";
---

<section class="py-24 bg-slate-900 relative">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div class="flex items-center gap-6 mb-16">
            <h2
                class="text-4xl md:text-5xl font-black text-cyan-400 uppercase tracking-widest drop-shadow-[0_0_10px_rgba(34,211,238,0.6)]"
            >
                Registro_Experiencia
            </h2>
            <div
                class="flex-1 h-[2px] bg-gradient-to-r from-cyan-400 to-transparent"
            >
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {
                experiences.map((exp, i) => (
                    <div class="relative bg-black/40 border border-slate-800 p-6 rounded-xl backdrop-blur-md flex flex-col group hover:border-cyan-500/50 transition-colors">
                        {/* Cyber accents */}
                        <div class="absolute top-0 left-0 w-12 h-12 border-t-2 border-l-2 border-cyan-500/0 group-hover:border-cyan-500/50 transition-colors rounded-tl-xl pointer-events-none" />
                        <div class="absolute bottom-0 right-0 w-12 h-12 border-b-2 border-r-2 border-fuchsia-500/0 group-hover:border-fuchsia-500/50 transition-colors rounded-br-xl pointer-events-none" />

                        <div class="relative z-10 flex flex-col h-full">
                            {exp.featured && exp.link && (
                                <a
                                    href={exp.link}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="block w-full aspect-video mb-6 border border-fuchsia-500/30 relative overflow-hidden group/iframe shadow-[0_0_15px_rgba(217,70,239,0.1)] hover:shadow-[0_0_20px_rgba(34,211,238,0.3)] transition-all"
                                >
                                    <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,0,0,0.5)_50%)] bg-[length:100%_4px] pointer-events-none z-20 opacity-50 group-hover/iframe:opacity-30 transition-opacity" />
                                    <div class="absolute inset-0 bg-cyan-900/0 group-hover/iframe:bg-cyan-900/40 z-10 transition-colors flex items-center justify-center">
                                        <span class="opacity-0 group-hover/iframe:opacity-100 text-cyan-300 font-mono tracking-widest border border-cyan-400 bg-black/60 px-4 py-2 text-sm uppercase shadow-[0_0_10px_rgba(34,211,238,0.5)] transition-all">
                                            ESTABLECER_ENLACE
                                        </span>
                                    </div>
                                    <iframe
                                        src={exp.link}
                                        class="w-[200%] h-[200%] border-0 transform scale-50 origin-top-left pointer-events-none mix-blend-screen opacity-70 group-hover/iframe:opacity-100 contrast-125 saturate-150 transition-all duration-500"
                                        loading="lazy"
                                        title={exp.company}
                                    />
                                </a>
                            )}
                            <div class="flex flex-col xl:flex-row xl:justify-between xl:items-start mb-4 gap-3">
                                <div>
                                    <h3 class="text-xl md:text-2xl font-bold text-white mb-1 tracking-wide group-hover:text-cyan-400 transition-colors">
                                        <a
                                            href={exp.link || "#"}
                                            target={
                                                exp.link ? "_blank" : "_self"
                                            }
                                        >
                                            {exp.role}
                                        </a>
                                    </h3>
                                    <div class="text-fuchsia-400 font-mono text-sm font-bold drop-shadow-[0_0_5px_rgba(217,70,239,0.5)]">
                                        @{exp.company}
                                    </div>
                                </div>
                                <div class="bg-cyan-950/50 text-cyan-300 border border-cyan-500/30 px-3 py-1.5 font-mono text-xs self-start">
                                    [{exp.period}]
                                </div>
                            </div>

                            <p class="text-slate-300 text-sm mb-6 leading-relaxed max-w-3xl border-l-2 border-slate-700 pl-3">
                                {exp.description}
                            </p>

                            <div class="grid grid-cols-1 gap-3">
                                {exp.impact.map((impact) => {
                                    const [title, ...rest] = impact.split(": ");
                                    return (
                                        <div class="flex items-start gap-3 p-3 bg-slate-800/30 border border-slate-700/50 rounded hover:bg-slate-800/60 transition-colors">
                                            <div class="mt-1 text-cyan-400">
                                                ▹
                                            </div>
                                            <div>
                                                <span class="text-fuchsia-300 font-bold uppercase text-sm tracking-wider mr-2">
                                                    {title}:
                                                </span>
                                                <span class="text-cyan-100 font-mono text-sm leading-relaxed">
                                                    {rest.join(": ")}
                                                </span>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
