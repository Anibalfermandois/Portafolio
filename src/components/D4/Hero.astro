---
import { Image } from "astro:assets";
import profileImage from "../../assets/profile.png";
import { personalInfo } from "../../data/portfolio";
---

<header
    class="relative pt-32 pb-20 overflow-hidden border-b-4 border-fuchsia-500 bg-slate-900"
>
    {/* Cyberpunk Grid Background */}
    <div
        class="absolute inset-0 bg-[linear-gradient(transparent_95%,rgba(217,70,239,0.3)_100%),linear-gradient(90deg,transparent_95%,rgba(6,182,212,0.3)_100%)] bg-[length:40px_40px] [transform:perspective(500px)_rotateX(60deg)_translateY(-100px)_translateZ(-200px)] [transform-origin:top_center] opacity-40"
    >
    </div>

    <div
        class="max-w-6xl mx-auto px-6 relative z-10 flex flex-col md:flex-row items-center gap-16"
    >
        <div class="flex-1 text-center md:text-left">
            <div
                class="inline-block bg-cyan-950 border border-cyan-400 text-cyan-400 px-4 py-1 mb-6 font-mono text-sm shadow-[0_0_10px_rgba(34,211,238,0.5)]"
            >
                &gt; SISTEMA.INICIALIZAR(USUARIO);
            </div>

            <h1
                class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-fuchsia-500 to-purple-600 mb-2 uppercase tracking-widest drop-shadow-[0_0_15px_rgba(217,70,239,0.5)]"
            >
                {personalInfo.name}
            </h1>

            <h2
                class="text-2xl md:text-3xl text-fuchsia-400 font-bold mb-8 uppercase tracking-wider drop-shadow-[0_0_8px_rgba(217,70,239,0.8)]"
            >
                {personalInfo.title}
            </h2>

            <div
                class="bg-black/60 border border-fuchsia-500/30 p-6 rounded-lg backdrop-blur-sm shadow-[inset_0_0_20px_rgba(217,70,239,0.1)] relative overflow-hidden group"
            >
                <div
                    class="absolute left-0 top-0 w-1 h-full bg-gradient-to-b from-cyan-400 to-fuchsia-500"
                >
                </div>
                <p
                    class="text-cyan-100 text-lg leading-relaxed relative z-10 font-sans"
                >
                    {personalInfo.summary}
                </p>
                {/* Scanning Line Effect */}
                <div
                    class="absolute w-full h-[2px] bg-cyan-400/50 top-[-100%] group-hover:animate-[scan_2s_ease-in-out_infinite] blur-[1px]"
                >
                </div>
            </div>

            <div class="mt-10 flex gap-6 justify-center md:justify-start">
                <a
                    href={`mailto:${personalInfo.contact}`}
                    class="relative px-8 py-4 bg-fuchsia-600 text-white font-bold uppercase tracking-widest rounded shadow-[0_0_15px_rgba(217,70,239,0.8)] hover:shadow-[0_0_25px_rgba(217,70,239,1)] transition-all overflow-hidden group border border-fuchsia-400"
                >
                    <span class="relative z-10">INICIAR_CONTACTO</span>
                    <div
                        class="absolute inset-0 bg-gradient-to-r from-fuchsia-400 to-purple-600 opacity-0 group-hover:opacity-100 transition-opacity"
                    >
                    </div>
                </a>
            </div>
        </div>

        <div class="relative w-64 h-64 md:w-80 md:h-80 shrink-0">
            {/* Glitch Frame */}
            <div
                class="absolute inset-0 border-2 border-cyan-400 rounded-full shadow-[0_0_20px_rgba(34,211,238,0.5)] animate-pulse"
            >
            </div>
            <div
                class="absolute inset-[-4px] border border-fuchsia-500 rounded-full border-dashed animate-[spin_10s_linear_infinite] opacity-50"
            >
            </div>

            <div
                class="w-full h-full rounded-full overflow-hidden relative z-10 border-4 border-slate-900 bg-black"
            >
                <Image
                    src={profileImage}
                    alt={personalInfo.name}
                    class="w-full h-full object-cover mix-blend-screen contrast-125 saturate-[1.5] sepia-[0.3] hue-rotate-[-30deg]"
                    loading="eager"
                />
                {/* CRT Overlay on Image */}
                <div
                    class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,0,0,0.25)_50%)] bg-[length:100%_4px] pointer-events-none"
                >
                </div>
            </div>
        </div>
    </div>
</header>
