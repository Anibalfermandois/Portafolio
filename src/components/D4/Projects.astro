---
import { Image } from "astro:assets";
import { projects } from "../../data/portfolio";

const projectImages: Record<string, any> = {
    Anikio: import("../../assets/Anikio.webp"),
    "BCI++": import("../../assets/bci2.png"),
    Excluido: import("../../assets/excluido.jpg"),
    RecordaBot: import("../../assets/recordabot.png"),
};
---

<section class="py-24 bg-slate-900 relative border-t border-fuchsia-500/30">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div
            class="inline-block border border-fuchsia-500 bg-fuchsia-950/50 px-6 py-2 mb-16 shadow-[0_0_15px_rgba(217,70,239,0.5)] transform -skew-x-12"
        >
            <h2
                class="text-4xl md:text-5xl font-black text-fuchsia-400 uppercase tracking-widest transform skew-x-12"
            >
                Núcleo_Datos::Proyectos
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            {
                projects.map((project, index) => (
                    <a
                        href={project.link || "#"}
                        target={project.link ? "_blank" : "_self"}
                        class="group block h-full"
                    >
                        <div class="h-full bg-slate-950 border-2 border-slate-800 p-1 relative overflow-hidden transition-all duration-300 hover:border-cyan-400 hover:shadow-[0_0_20px_rgba(34,211,238,0.4)]">
                            {/* Cyberpunk corner decorations */}
                            <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-cyan-400 opacity-0 group-hover:opacity-100 transition-opacity" />
                            <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-fuchsia-500 opacity-0 group-hover:opacity-100 transition-opacity" />

                            <div class="flex flex-col h-full bg-slate-900/80 backdrop-blur">
                                <div class="h-8 bg-slate-800 border-b border-slate-700 flex items-center px-4 justify-between font-mono text-xs text-slate-400">
                                    <span class="text-cyan-400 animate-pulse">
                                        ■ RECORD_
                                        {index.toString().padStart(3, "0")}
                                    </span>
                                    <span>
                                        {project.name.toUpperCase()}.EXE
                                    </span>
                                </div>

                                <div class="relative overflow-hidden aspect-video border-b border-slate-800 bg-black">
                                    {projectImages[project.name] ? (
                                        <Image
                                            src={projectImages[project.name]}
                                            alt={project.name}
                                            class="w-full h-full object-cover mix-blend-screen opacity-70 group-hover:opacity-100 transition-opacity duration-500 contrast-[1.2] saturate-150 group-hover:scale-105"
                                        />
                                    ) : (
                                        <div class="w-full h-full flex items-center justify-center font-mono text-fuchsia-500 text-sm border-y border-dashed border-fuchsia-500/30">
                                            <span class="animate-pulse">
                                                ESPERANDO_DATOS_VISUALES...
                                            </span>
                                        </div>
                                    )}
                                    {/* Scanline Overlay */}
                                    <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,0,0,0.5)_50%)] bg-[length:100%_4px] pointer-events-none opacity-50 group-hover:opacity-30" />
                                </div>

                                <div class="p-6 flex-col flex flex-1">
                                    <h3 class="text-2xl font-black text-white mb-3 tracking-widest uppercase group-hover:text-cyan-400 transition-colors drop-shadow-[0_0_5px_rgba(34,211,238,0.5)]">
                                        {project.name}
                                    </h3>

                                    <p class="text-slate-400 font-sans leading-relaxed mb-6 flex-1 text-sm md:text-base">
                                        {project.description}
                                    </p>

                                    <div class="flex flex-wrap gap-2 mt-auto">
                                        {project.technologies.map((tech) => (
                                            <span class="bg-fuchsia-950/40 text-fuchsia-300 border border-fuchsia-500/30 font-mono text-[10px] uppercase tracking-wider px-2 py-1 rounded-sm shadow-[inset_0_0_5px_rgba(217,70,239,0.2)]">
                                                {tech}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
