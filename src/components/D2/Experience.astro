---
import { experiences } from "../../data/portfolio";
import Popover from "./Popover.astro";
---

<section class="py-24 border-b border-slate-800">
    <div class="max-w-4xl mx-auto px-6">
        <div class="flex items-center gap-4 mb-16">
            <h2 class="text-3xl font-bold text-white">Experiencia</h2>
            <div
                class="h-[1px] flex-1 bg-gradient-to-r from-slate-800 to-transparent"
            >
            </div>
            <Popover
                text="Mapeado sobre un AST tipo JSON importado estáticamente, evitando hidratación en el cliente."
                metric="0kb JS"
            >
                <span
                    class="font-mono text-xs text-slate-500 bg-slate-800/50 px-2 py-1 rounded"
                    >Array.map()</span
                >
            </Popover>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-6 ml-3 md:ml-0"
        >
            {
                experiences.map((exp, i) => (
                    <div class="relative pl-6 md:pl-8 border-l border-slate-800 flex flex-col h-full group">
                        {/* Node */}
                        <div class="absolute w-5 h-5 bg-slate-900 border border-emerald-500/30 rounded-full left-[-10px] top-1 flex items-center justify-center">
                            <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full" />
                        </div>

                        {exp.featured && exp.link && (
                            <div class="mb-4 relative rounded-lg border border-slate-800 overflow-hidden aspect-video bg-slate-900 group-hover:border-emerald-500/50 transition-colors lg:w-full">
                                <a
                                    href={exp.link}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="absolute inset-0 z-10 flex items-center justify-center bg-slate-900/0 hover:bg-slate-900/40 transition-all"
                                >
                                    <span class="opacity-0 hover:opacity-100 border border-emerald-500 text-emerald-400 px-4 py-2 font-mono text-xs uppercase bg-slate-900/80 backdrop-blur transition-all">
                                        [ INITIATE_CONNECTION ]
                                    </span>
                                </a>
                                <iframe
                                    src={exp.link}
                                    class="w-[200%] h-[200%] border-0 transform scale-50 origin-top-left pointer-events-none opacity-50 contrast-125 group-hover:opacity-100 transition-opacity"
                                    loading="lazy"
                                    title={exp.company}
                                />
                            </div>
                        )}

                        <div class="flex flex-col xl:flex-row xl:items-baseline gap-2 md:gap-3 mb-2 mt-2">
                            <h3 class="text-xl font-bold text-slate-100 group-hover:text-emerald-400 transition-colors">
                                <a
                                    href={exp.link || "#"}
                                    target={exp.link ? "_blank" : "_self"}
                                >
                                    {exp.role}
                                </a>
                            </h3>
                            <span class="text-emerald-400 font-mono text-xs">
                                @ {exp.company}
                            </span>
                        </div>

                        <div class="text-slate-500 font-mono text-xs mb-4 flex items-center gap-3">
                            <span class="bg-slate-800/50 px-2 py-1 rounded border border-slate-700/50">
                                {exp.period}
                            </span>
                        </div>

                        <p class="text-slate-300 mb-4 font-mono text-xs leading-relaxed max-w-2xl">
                            {exp.description}
                        </p>

                        <div class="space-y-3 max-w-3xl">
                            {exp.impact.map((impact) => {
                                const [title, ...rest] = impact.split(": ");
                                return (
                                    <div class="bg-slate-800/30 border border-slate-800 rounded-lg p-3 font-mono text-xs hover:border-slate-700 hover:bg-slate-800/50 transition-colors">
                                        <span class="text-emerald-300 font-bold">
                                            {title}
                                        </span>
                                        <span class="text-slate-400 ml-2">
                                            {rest.length
                                                ? `// ${rest.join(": ")}`
                                                : ""}
                                        </span>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
