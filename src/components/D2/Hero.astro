---
import { Image } from "astro:assets";
import profileImage from "../../assets/profile.png";
import { personalInfo } from "../../data/portfolio";
import Popover from "./Popover.astro";
---

<header class="py-24 border-b border-slate-800">
    <div
        class="max-w-4xl mx-auto px-6 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-12 items-center"
    >
        <div>
            <div class="text-emerald-400 font-mono text-sm mb-4">
                <Popover
                    text="Renderizado como HTML estático en tiempo de compilación para 0ms de tiempo de procesamiento en el servidor."
                    metric="SSG"
                >
                    <span class="text-emerald-400">~/profile/init</span>
                </Popover>
            </div>
            <h1
                class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight"
            >
                {personalInfo.name}
            </h1>
            <h2 class="text-xl md:text-2xl text-slate-400 font-mono mb-8">
                <Popover
                    text="Propiedades de componentes compiladas estáticamente y seguras de tipos."
                    metric="TypeScript"
                >
                    <span class="pb-1">{personalInfo.title}</span>
                </Popover>
            </h2>
            <p class="text-slate-300 leading-relaxed text-lg max-w-xl">
                {personalInfo.summary}
            </p>
        </div>

        <div
            class="relative w-48 h-48 md:w-64 md:h-64 rounded-xl overflow-hidden border border-slate-700 bg-slate-800/50 p-2"
        >
            <Popover
                text="Auto-optimizado a formato WebP, redimensionado y cabeceras de caché inmutables."
                metric="-65% size"
            >
                <div
                    class="w-full h-full rounded-lg overflow-hidden relative group"
                >
                    <Image
                        src={profileImage}
                        alt={personalInfo.name}
                        class="w-full h-full object-cover mix-blend-luminosity hover:mix-blend-normal transition-all duration-500"
                        loading="eager"
                    />
                    <div
                        class="absolute inset-0 border border-white/10 rounded-lg pointer-events-none"
                    >
                    </div>
                </div>
            </Popover>
        </div>
    </div>
</header>
