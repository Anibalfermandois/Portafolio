---
import { Image } from "astro:assets";
import { projects } from "../../data/portfolio";
import Popover from "./Popover.astro";

const projectImages: Record<string, any> = {
    Anikio: import("../../assets/Anikio.webp"),
    "BCI++": import("../../assets/bci2.png"),
    Excluido: import("../../assets/excluido.jpg"),
    RecordaBot: import("../../assets/recordabot.png"),
};
---

<section class="py-24 border-b border-slate-800">
    <div class="max-w-4xl mx-auto px-6">
        <div class="flex items-center justify-between mb-16">
            <div class="flex items-center gap-4">
                <h2 class="text-3xl font-bold text-white">Proyectos</h2>
                <div class="h-[1px] w-12 bg-slate-800"></div>
            </div>
            <Popover
                text="Componentes diferidos (lazy-loaded) vía integración de Intersection Observer."
                metric="Lazy"
            >
                <span
                    class="font-mono text-xs text-emerald-400 bg-emerald-400/10 px-2 py-1 rounded border border-emerald-400/20 px-2 py-1"
                    >intersection-observer</span
                >
            </Popover>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {
                projects.map((project) => (
                    <a
                        href={project.link || "#"}
                        target={project.link ? "_blank" : "_self"}
                        class="group block h-full"
                    >
                        <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden h-full flex flex-col hover:border-emerald-500/50 transition-colors">
                            <div class="bg-slate-800/50 px-4 py-3 border-b border-slate-800 flex items-center justify-between">
                                <div class="flex gap-2">
                                    <div class="w-3 h-3 rounded-full bg-slate-700 group-hover:bg-red-500/80 transition-colors" />
                                    <div class="w-3 h-3 rounded-full bg-slate-700 group-hover:bg-amber-500/80 transition-colors" />
                                    <div class="w-3 h-3 rounded-full bg-slate-700 group-hover:bg-emerald-500/80 transition-colors" />
                                </div>
                                <span class="text-xs font-mono text-slate-500">
                                    {project.name
                                        .toLowerCase()
                                        .replace(/\s+/g, "-")}
                                    .tsx
                                </span>
                            </div>

                            <div class="aspect-video bg-black relative overflow-hidden group">
                                {projectImages[project.name] ? (
                                    <Image
                                        src={projectImages[project.name]}
                                        alt={project.name}
                                        class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-300"
                                    />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center text-slate-600 font-mono text-sm border-y border-dashed border-slate-800">
                                        <Popover
                                            text="Componente por defecto renderizado. Sin carga de recursos."
                                            metric="0kb"
                                        >
                                            Imagen no disponible
                                        </Popover>
                                    </div>
                                )}
                            </div>

                            <div class="p-6 flex-1 flex flex-col bg-slate-900">
                                <h3 class="text-xl font-bold text-slate-100 mb-3 group-hover:text-emerald-400 transition-colors font-mono">
                                    {project.name}
                                </h3>
                                <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-1">
                                    {project.description}
                                </p>

                                <div class="flex flex-wrap gap-2 mt-auto">
                                    {project.technologies.map((tech) => (
                                        <span class="text-[10px] font-mono font-medium text-emerald-300/70 bg-emerald-900/20 border border-emerald-900/50 px-2 py-1 rounded">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
