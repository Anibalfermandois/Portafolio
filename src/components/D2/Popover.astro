---
interface Props {
    text: string;
    metric?: string;
}

const { text, metric } = Astro.props;
---

<div
    class="group relative inline-flex items-center cursor-help border-b border-dashed border-emerald-500/50 hover:border-emerald-400 transition-colors"
>
    <slot />

    <div
        class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-max max-w-xs opacity-0 group-hover:opacity-100 transition-all duration-200 translate-y-2 group-hover:translate-y-0 z-50"
    >
        <div
            class="bg-slate-800 border border-slate-700 rounded-md shadow-xl overflow-hidden text-left flex flex-col"
        >
            <div
                class="bg-slate-900/50 px-3 py-1.5 border-b border-slate-700/50 flex justify-between items-center gap-4"
            >
                <span
                    class="text-[10px] font-mono text-slate-400 uppercase tracking-wider"
                    >Optimización</span
                >
                {
                    metric && (
                        <span class="text-[10px] font-mono text-emerald-400 bg-emerald-400/10 px-1.5 rounded">
                            {metric}
                        </span>
                    )
                }
            </div>
            <div
                class="px-3 py-2 text-xs font-mono text-slate-300 leading-relaxed"
            >
                {text}
            </div>
        </div>
        <!-- Caret -->
        <div
            class="w-3 h-3 bg-slate-800 border-r border-b border-slate-700 absolute -bottom-1.5 left-1/2 -translate-x-1/2 rotate-45"
        >
        </div>
    </div>
</div>
