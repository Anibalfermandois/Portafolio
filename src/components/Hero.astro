---
import { Image } from "astro:assets";
import profileImage from "../assets/profile.png";
import ucLogo from "../assets/uc.jpg";
import { getEntry, render } from "astro:content";

const personalInfoEntry = await getEntry("personal", "info");
if (!personalInfoEntry) throw new Error("Missing personal info entry");
const { Content: PersonalSummary } = await render(personalInfoEntry);
const personalInfo = personalInfoEntry.data;
---

<section
    class="max-w-5xl mx-auto px-6 pt-24 pb-16 md:pt-32 md:pb-24 flex flex-col-reverse md:flex-row items-center gap-12"
>
    <div class="flex-1 text-center md:text-left">
        <h1
            class="text-4xl md:text-6xl font-extrabold text-slate-900 tracking-tight mb-4 flex flex-col md:flex-row items-center justify-center md:justify-start gap-3 md:gap-4"
        >
            <span>Hola, soy {personalInfo.name}</span>
            <Image
                src={ucLogo}
                alt="Pontificia Universidad Católica de Chile"
                class="h-12 md:h-16 lg:h-25 w-auto object-contain"
            />
        </h1>
        <h2 class="text-xl md:text-2xl text-blue-600 font-medium mb-6">
            {personalInfo.title}
        </h2>
        <div
            class="text-lg text-slate-600 leading-relaxed mb-8 max-w-2xl [&>p]:mb-0"
        >
            <PersonalSummary />
        </div>
        <div class="flex flex-wrap justify-center md:justify-start gap-4">
            <a
                href={personalInfo.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-[#0077b5] hover:bg-[#005582] text-white px-6 py-3 rounded-lg font-medium transition-colors flex items-center gap-2"
            >
                <svg
                    class="w-5 h-5 fill-current"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                >
                    <path
                        d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                    ></path>
                </svg>
                LinkedIn
            </a>
            <a
                href={`mailto:${personalInfo.contact}`}
                class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition-colors"
            >
                Contáctame
            </a>
            <a
                href="/CV.pdf"
                target="_blank"
                class="bg-[rgba(128,0,0,0.1)] hover:bg-[rgba(128,0,0,0.2)] text-[rgb(128,0,0)] border border-[rgba(128,0,0,0.3)] px-6 py-3 rounded-lg font-medium transition-colors"
            >
                Ver CV
            </a>
        </div>
    </div>
    <div
        class="relative w-48 h-48 md:w-80 md:h-80 shrink-0 group perspective-1000"
    >
        <Image
            src={profileImage}
            alt={personalInfo.name}
            class="w-full h-full object-cover rounded-full shadow-2xl ring-4 ring-white transition-transform duration-500 ease-out group-hover:scale-105 cursor-pointer z-10 relative"
            loading="eager"
        />
    </div>
</section>
