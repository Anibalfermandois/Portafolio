---
// src/components/Hero.astro
import { Image } from 'astro:assets'
import profile from '../assets/profile.png'
---

<section class="flex flex-col md:flex-row items-center justify-between gap-12 py-16 md:py-24">
  <div class="flex-1 text-center md:text-left">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-[var(--sl-color-white)] mb-4 tracking-tight leading-tight">
      Aníbal Fermandois
    </h1>
    <h2 class="text-xl md:text-2xl text-[var(--sl-color-accent)] font-semibold mb-6">
      AI Infrastructure & Full Stack Developer
    </h2>
    <p class="text-lg text-[var(--sl-color-gray-2)] leading-relaxed max-w-2xl mx-auto md:mx-0">
      Desarrollador Full Stack con una sólida formación en Ingeniería Civil de la Pontificia Universidad Católica.
      Apasionado por resolver problemas complejos a través de la tecnología, mi objetivo es diseñar y construir soluciones digitales eficientes, robustas y escalables. 
      Desde inicios de 2025, aplico y expando mis habilidades en el equipo de Nikola.
    </p>
    <div class="mt-8 flex flex-wrap gap-4 justify-center md:justify-start">
      <a href="/contact" class="px-6 py-3 bg-[var(--sl-color-accent)] text-white font-bold rounded-full hover:opacity-90 transition-opacity">
        Contáctame
      </a>
      <a href="#projects" class="px-6 py-3 border border-[var(--sl-color-gray-4)] text-[var(--sl-color-white)] font-bold rounded-full hover:bg-[var(--sl-color-gray-6)] transition-colors">
        Ver Proyectos
      </a>
    </div>
  </div>
  
  <div class="w-48 h-48 md:w-64 md:h-64 lg:w-80 lg:h-80 flex-shrink-0 relative">
    <div class="absolute inset-0 bg-gradient-to-tr from-[var(--sl-color-accent)] to-purple-500 rounded-full blur-2xl opacity-20 animate-pulse"></div>
    <Image
      src={profile}
      alt="Aníbal Fermandois"
      class="rounded-full w-full h-full object-cover border-4 border-[var(--sl-color-gray-6)] shadow-2xl relative z-10"
    />
  </div>
</section>
