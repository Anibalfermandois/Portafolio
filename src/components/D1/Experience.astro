---
import { experiences } from "../../data/portfolio";
---

<section id="experience" class="bg-slate-50 py-20 px-6">
    <div class="max-w-5xl mx-auto">
        <h2
            class="text-3xl font-bold text-slate-900 mb-12 flex items-center gap-4"
        >
            <span class="w-8 h-1 bg-blue-600 rounded-full"></span>
            Experiencia Laboral
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {
                experiences.map((exp) => (
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 transition-all hover:shadow-md flex flex-col group relative">
                        {exp.featured && exp.link && (
                            <a
                                href={exp.link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="block w-full aspect-video mb-4 rounded-xl overflow-hidden border border-slate-200 shadow-inner group-hover:border-blue-400 transition-colors relative"
                            >
                                <div class="absolute inset-0 bg-blue-600/0 group-hover:bg-blue-600/10 transition-colors z-10 flex items-center justify-center">
                                    <span class="opacity-0 group-hover:opacity-100 bg-blue-600 text-white px-4 py-2 rounded-lg font-medium shadow-lg transform translate-y-2 group-hover:translate-y-0 transition-all">
                                        Visitar Sitio Web
                                    </span>
                                </div>
                                <iframe
                                    src={exp.link}
                                    class="w-[200%] h-[200%] border-0 transform scale-50 origin-top-left pointer-events-none"
                                    loading="lazy"
                                    title={exp.company}
                                />
                            </a>
                        )}
                        <div class="flex flex-col xl:flex-row xl:justify-between xl:items-start mb-4 gap-3">
                            <div>
                                <h3 class="text-xl font-bold text-slate-900">
                                    {exp.link ? (
                                        <a
                                            href={exp.link}
                                            target="_blank"
                                            class="hover:text-blue-600 transition-colors"
                                        >
                                            {exp.role}
                                        </a>
                                    ) : (
                                        exp.role
                                    )}
                                </h3>
                                <div class="text-blue-600 font-medium mt-1 inline-flex items-center gap-2">
                                    {exp.company}
                                    {exp.featured && (
                                        <span class="bg-blue-100 text-blue-700 text-[10px] uppercase font-bold px-2 py-0.5 rounded-full">
                                            Destacado
                                        </span>
                                    )}
                                </div>
                            </div>
                            <div class="text-slate-500 text-sm mt-2 xl:mt-0 font-medium bg-slate-100 px-3 py-1 rounded-full w-fit">
                                {exp.period}
                            </div>
                        </div>

                        <p class="text-slate-700 mb-4 text-sm font-medium leading-relaxed">
                            {exp.description}
                        </p>

                        <ul class="space-y-2">
                            {exp.impact.map((item) => {
                                const [title, ...rest] = item.split(": ");
                                return (
                                    <li class="flex items-start text-slate-600 leading-relaxed text-sm">
                                        <span class="mr-3 text-blue-500 mt-1.5">
                                            •
                                        </span>
                                        <span>
                                            <strong class="text-slate-800">
                                                {title}:
                                            </strong>{" "}
                                            {rest.join(": ")}
                                        </span>
                                    </li>
                                );
                            })}
                        </ul>
                    </div>
                ))
            }
        </div>
    </div>
</section>
