---
interface Props {
  src: string;
  title?: string;
  label?: string;
}

const { src, title = "Website Preview", label } = Astro.props;
---

<div class="my-6">
    <a
        href={src}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full aspect-video rounded-2xl overflow-hidden border border-slate-200 shadow-inner hover:border-blue-400 hover:shadow-md transition-all relative group/preview"
    >
        <div class=" bg-blue-600/0 group-hover/preview:bg-blue-600/10 transition-colors z-10 flex items-center justify-center">
        </div>
        <iframe
            src={src}
            class="w-[200%] h-[200%] border-0 transform scale-50 origin-top-left pointer-events-none"
            loading="lazy"
            title={title}
        />
    </a>
    {label && (
        <p class="text-center text-xs text-slate-400 mt-2 font-medium">
            {label}
        </p>
    )}
</div>
