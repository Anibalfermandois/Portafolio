---
import { experiences } from "../../data/portfolio";
---

<section class="py-32 relative px-6 z-10">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-24">
            <h2
                class="text-4xl md:text-5xl font-serif text-stone-900 mb-6 italic"
            >
                Experiencia Destacada
            </h2>
            <div class="w-16 h-px bg-stone-300 mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
            {
                experiences.map((exp, index) => (
                    <div class="group flex flex-col h-full w-full max-w-2xl mx-auto">
                        <div class="flex flex-col mb-8">
                            <div class="text-sm font-semibold tracking-[0.2em] text-stone-400 uppercase mb-4 relative inline-block">
                                <span class="absolute top-1/2 -left-8 w-4 h-px bg-stone-300 hidden md:block transform transition-transform group-hover:scale-x-150 origin-right" />
                                {exp.period}
                            </div>
                            <div>
                                <h3 class="text-3xl font-serif text-stone-900 mb-2 group-hover:text-amber-800 transition-colors">
                                    <a
                                        href={exp.link || "#"}
                                        target={exp.link ? "_blank" : "_self"}
                                    >
                                        {exp.role}
                                    </a>
                                </h3>
                                <div class="text-lg text-rose-800/80 italic font-serif flex items-center gap-3">
                                    {exp.company}
                                    {exp.featured && (
                                        <span class="text-[10px] uppercase tracking-widest font-sans border border-rose-200 bg-white/50 px-2 py-0.5 rounded-full text-rose-600">
                                            Destacada
                                        </span>
                                    )}
                                </div>
                            </div>
                        </div>

                        <div class="flex-1 flex flex-col">
                            {/* Glassmorphism Card */}
                            <div class="bg-white/40 backdrop-blur-xl border border-white/60 rounded-2xl p-8 shadow-[0_8px_32px_0_rgba(31,38,135,0.03)] hover:shadow-[0_8px_32px_0_rgba(31,38,135,0.08)] hover:bg-white/60 transition-all duration-500 flex-1 flex flex-col">
                                {exp.featured && exp.link && (
                                    <a
                                        href={exp.link}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="block w-full aspect-video mb-8 rounded-xl overflow-hidden relative group/iframe shadow-sm hover:shadow-md transition-all"
                                    >
                                        <div class="absolute inset-0 bg-stone-900/0 group-hover/iframe:bg-stone-900/5 mix-blend-overlay z-10 transition-colors" />
                                        <iframe
                                            src={exp.link}
                                            class="w-[200%] h-[200%] border-0 transform scale-50 origin-top-left pointer-events-none opacity-90 group-hover/iframe:opacity-100 transition-opacity"
                                            loading="lazy"
                                            title={exp.company}
                                        />
                                    </a>
                                )}
                                <p class="text-stone-600 text-lg leading-relaxed mb-8 font-light">
                                    {exp.description}
                                </p>

                                <div class="space-y-6">
                                    {exp.impact.map((impact) => {
                                        const [title, ...rest] =
                                            impact.split(": ");
                                        return (
                                            <div class="flex items-start gap-4 text-stone-600">
                                                <span class="text-rose-300 text-xl font-serif leading-none mt-1">
                                                    ~
                                                </span>
                                                <p class="font-light leading-relaxed">
                                                    <strong class="font-semibold text-stone-800 font-sans tracking-wide text-sm uppercase">
                                                        {title}
                                                    </strong>
                                                    <span class="mx-2">
                                                        &mdash;
                                                    </span>
                                                    {rest.join(": ")}
                                                </p>
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
