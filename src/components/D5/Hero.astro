---
import { Image } from "astro:assets";
import profileImage from "../../assets/profile.png";
import { personalInfo } from "../../data/portfolio";
---

<header
    class="min-h-[90vh] flex flex-col justify-center relative overflow-hidden px-6 py-24"
>
    {/* Abstract Soft Pastel Background Elements */}
    <div
        class="absolute top-0 right-0 w-[800px] h-[800px] bg-rose-200/40 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none mix-blend-multiply"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-teal-200/40 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4 pointer-events-none mix-blend-multiply"
    >
    </div>
    <div
        class="absolute top-1/2 left-1/2 w-[500px] h-[500px] bg-amber-100/50 rounded-full blur-[90px] -translate-x-1/2 -translate-y-1/2 pointer-events-none mix-blend-multiply"
    >
    </div>

    <div
        class="max-w-6xl mx-auto w-full relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 items-center"
    >
        <div
            class="lg:col-span-7 flex flex-col justify-center order-2 lg:order-1"
        >
            <div class="inline-flex items-center gap-4 mb-8">
                <span class="w-12 h-[1px] bg-stone-800"></span>
                <span
                    class="text-stone-500 tracking-[0.2em] uppercase text-xs font-semibold"
                >
                    {personalInfo.title}
                </span>
            </div>

            <h1
                class="text-6xl md:text-8xl font-serif text-stone-900 leading-[1.1] mb-8 tracking-tight"
            >
                Aníbal<br />
                <span class="italic text-stone-600 font-light">Fermandois</span>
            </h1>

            <p
                class="text-xl md:text-2xl text-stone-600 font-light leading-relaxed max-w-2xl mb-12"
            >
                {personalInfo.summary}
            </p>

            <div class="flex items-center gap-8">
                <a
                    href={`mailto:${personalInfo.contact}`}
                    class="group relative px-8 py-4 bg-stone-900 text-stone-100 overflow-hidden transition-all hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.3)] hover:-translate-y-1"
                >
                    <span
                        class="relative z-10 uppercase tracking-widest text-sm font-semibold"
                        >Ponte en Contacto</span
                    >
                    <div
                        class="absolute inset-0 bg-stone-800 transform scale-x-0 origin-left group-hover:scale-x-100 transition-transform duration-500"
                    >
                    </div>
                </a>
            </div>
        </div>

        <div
            class="lg:col-span-5 order-1 lg:order-2 flex justify-center lg:justify-end"
        >
            <div class="relative w-64 h-80 md:w-80 md:h-[450px]">
                {/* Glassmorphism Frame behind image */}
                <div
                    class="absolute inset-x-8 -inset-y-8 bg-white/40 backdrop-blur-2xl border border-white/60 rounded-2xl shadow-[0_8px_32px_0_rgba(31,38,135,0.07)] transform rotate-3 transition-transform hover:rotate-6 duration-700"
                >
                </div>

                <div
                    class="relative w-full h-full rounded-2xl overflow-hidden shadow-2xl mix-blend-luminosity hover:mix-blend-normal transition-all duration-1000"
                >
                    <Image
                        src={profileImage}
                        alt={personalInfo.name}
                        class="w-full h-full object-cover"
                        loading="eager"
                    />
                </div>
            </div>
        </div>
    </div>
</header>
