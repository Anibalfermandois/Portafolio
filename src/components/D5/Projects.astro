---
import { Image } from "astro:assets";
import { projects } from "../../data/portfolio";

const projectImages: Record<string, any> = {
    Anikio: import("../../assets/Anikio.webp"),
    "BCI++": import("../../assets/bci2.png"),
    Excluido: import("../../assets/excluido.jpg"),
    RecordaBot: import("../../assets/recordabot.png"),
};
---

<section class="py-32 relative z-10 px-6">
    <div class="max-w-6xl mx-auto">
        <div
            class="flex items-center gap-6 mb-24 justify-center md:justify-start"
        >
            <h2 class="text-4xl md:text-5xl font-serif text-stone-900 italic">
                Trabajo Seleccionado
            </h2>
            <div
                class="h-[1px] flex-1 bg-gradient-to-r from-stone-300 to-transparent hidden md:block"
            >
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">
            {
                projects.map((project, index) => (
                    <a
                        href={project.link || "#"}
                        target={project.link ? "_blank" : "_self"}
                        class="group block"
                    >
                        <div
                            class={`h-full flex flex-col ${
                                index % 2 !== 0 ? "md:mt-24" : ""
                            }`}
                        >
                            <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden mb-8 shadow-sm group-hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] transition-all duration-700">
                                {/* Glass overlay on hover */}
                                <div class="absolute inset-x-4 inset-y-4 border border-white/40 rounded-xl z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none mix-blend-overlay" />

                                <div class="absolute inset-0 bg-stone-100/10 mix-blend-multiply z-10 group-hover:opacity-0 transition-opacity duration-700" />

                                {projectImages[project.name] ? (
                                    <Image
                                        src={projectImages[project.name]}
                                        alt={project.name}
                                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-stone-100/50 flex items-center justify-center font-serif italic text-stone-400">
                                        Arte pendiente
                                    </div>
                                )}
                            </div>

                            <div class="flex flex-col flex-1 px-4">
                                <h3 class="text-3xl font-serif text-stone-900 mb-4 group-hover:text-amber-800 transition-colors duration-500">
                                    {project.name}
                                </h3>

                                <p class="text-stone-500 font-light leading-relaxed mb-8 flex-1">
                                    {project.description}
                                </p>

                                <div class="flex flex-wrap gap-2 mt-auto pb-4">
                                    {project.technologies.map((tech) => (
                                        <span class="text-xs font-semibold tracking-widest uppercase text-stone-400 bg-white/50 border border-white backdrop-blur-sm px-3 py-1.5 rounded-full shadow-sm">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
