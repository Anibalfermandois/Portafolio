---
import { experiences } from "../../data/portfolio";
---

<section class="border-b-8 border-black bg-white">
    <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr]">
        {/* Sidebar title */}
        <div
            class="bg-black text-white p-6 lg:p-12 border-b-8 lg:border-b-0 lg:border-r-8 border-black flex items-center justify-center lg:items-start lg:w-48 xl:w-64"
        >
            <h2
                class="text-5xl md:text-7xl lg:text-8xl font-black uppercase tracking-tighter leading-none transform lg:-rotate-90 origin-center whitespace-nowrap lg:mt-64"
            >
                EXPERIENCIA
            </h2>
        </div>

        <div
            class="grid grid-cols-1 lg:grid-cols-2 divide-y-8 lg:divide-y-0 lg:divide-x-8 divide-black"
        >
            {
                experiences.map((exp, i) => (
                    <article class="p-4 md:p-8 hover:bg-yellow-400 transition-colors duration-300 relative group flex flex-col">
                        {exp.featured && exp.link && (
                            <a
                                href={exp.link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="block border-4 border-black w-full aspect-video overflow-hidden mb-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all relative group/iframe"
                            >
                                <div class="absolute inset-0 bg-blue-500/0 group-hover/iframe:bg-blue-500/20 mix-blend-multiply z-10 transition-colors" />
                                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-black text-white px-4 py-2 font-black text-xl uppercase tracking-widest z-20 opacity-0 group-hover/iframe:opacity-100 transition-opacity whitespace-nowrap">
                                    VISITAR LINK
                                </div>
                                <iframe
                                    src={exp.link}
                                    class="w-[200%] h-[200%] border-0 transform scale-50 origin-top-left pointer-events-none grayscale group-hover/iframe:grayscale-0 transition-all"
                                    loading="lazy"
                                    title={exp.company}
                                />
                            </a>
                        )}
                        <div class="flex flex-col xl:flex-row xl:items-start justify-between mb-6 gap-3">
                            <div>
                                <h3 class="text-3xl md:text-4xl font-black uppercase tracking-tight mb-2 group-hover:text-blue-600 transition-colors">
                                    <a
                                        href={exp.link || "#"}
                                        target={exp.link ? "_blank" : "_self"}
                                    >
                                        {exp.role}
                                    </a>
                                </h3>
                                <div class="text-xl md:text-2xl font-bold italic text-blue-600 border-4 border-blue-600 inline-block px-3 py-1 bg-white">
                                    {exp.company}
                                </div>
                            </div>

                            <div class="bg-black text-white px-4 py-2 font-bold text-lg uppercase tracking-widest self-start md:-rotate-2 shadow-[4px_4px_0px_0px_rgba(255,255,255,1)] border-4 border-black lg:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)]">
                                {exp.period}
                            </div>
                        </div>

                        <p class="text-lg md:text-xl font-bold mb-6 max-w-4xl border-l-4 border-black pl-4">
                            {exp.description}
                        </p>

                        <div class="grid grid-cols-1 gap-4">
                            {exp.impact.map((impact) => {
                                const [title, ...rest] = impact.split(": ");
                                return (
                                    <div class="border-4 border-black p-4 bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] group-hover:translate-x-1 group-hover:translate-y-1 group-hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all">
                                        <h4 class="text-lg font-black uppercase mb-2 text-red-500 bg-black inline-block px-2">
                                            {title}
                                        </h4>
                                        <p class="text-base font-bold leading-tight">
                                            {rest.join(": ")}
                                        </p>
                                    </div>
                                );
                            })}
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
