---
import { Image } from "astro:assets";
import profileImage from "../../assets/profile.png";
import { personalInfo } from "../../data/portfolio";
---

<header class="border-b-8 border-black bg-yellow-400">
    <div
        class="max-w-7xl mx-auto px-4 py-8 md:py-20 grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-0 lg:gap-12 items-end"
    >
        <div class="order-2 lg:order-1 relative z-10 -mt-10 lg:mt-0">
            <div
                class="bg-white border-8 border-black p-4 md:p-8 transform -rotate-2 hover:rotate-0 transition-transform duration-300 inline-block shadow-[16px_16px_0px_0px_rgba(0,0,0,1)]"
            >
                <h1
                    class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-4"
                >
                    ANÍBAL<br />FERMANDOIS
                </h1>
                <div
                    class="bg-black text-white px-4 py-2 text-xl md:text-3xl font-bold uppercase tracking-widest inline-block border-4 border-black mb-6"
                >
                    {personalInfo.title}
                </div>
                <p
                    class="text-xl md:text-2xl font-bold max-w-2xl leading-tight border-l-8 border-yellow-400 pl-4 bg-white"
                >
                    {personalInfo.summary}
                </p>
            </div>

            <div class="mt-12 flex gap-4">
                <a
                    href={`mailto:${personalInfo.contact}`}
                    class="bg-white border-4 border-black text-black font-black uppercase text-2xl px-8 py-4 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all"
                >
                    CONTACTO
                </a>
            </div>
        </div>

        <div class="order-1 lg:order-2 self-start lg:self-end">
            <div
                class="border-8 border-black bg-blue-500 w-[280px] h-[280px] md:w-[400px] md:h-[400px] overflow-hidden shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] transform rotate-3 hover:rotate-0 transition-transform duration-300"
            >
                <Image
                    src={profileImage}
                    alt={personalInfo.name}
                    class="w-full h-full object-cover"
                    loading="eager"
                />
            </div>
        </div>
    </div>
</header>

<div
    class="w-full h-12 border-b-8 border-black bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iNCIgaGVpZ2h0PSI0IiBmaWxsPSIjMDAwIiAvPgo8L3N2Zz4=')]"
>
</div>
