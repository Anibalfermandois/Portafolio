---
import { getCollection, render } from "astro:content";
import EditorialImage from "./EditorialImage.astro";

const projectsCollection = await getCollection("projects");
---

<section id="projects" class="py-20 px-6 max-w-5xl mx-auto reveal">
    <div class="flex justify-between items-end mb-12">
        <div>
            <h2
                class="text-3xl font-bold text-slate-900 mb-4 flex items-center gap-4"
            >
                <span class="w-8 h-1 bg-blue-600 rounded-full"></span>
                Proyectos Personales
            </h2>
            <p class="text-slate-500">
                Una selección de mis trabajos técnicos recientes.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
            projectsCollection.map(async (entry: any) => {
                const { Content } = await render(entry);
                const project = entry.data;
                return (
                    <a
                        href={project.link || "#"}
                        target={project.link ? "_blank" : "_self"}
                        class="group block h-full"
                    >
                        <div class="bg-white rounded-2xl overflow-hidden border border-slate-200 h-full flex flex-col transition-all hover:shadow-xl hover:-translate-y-1">
                            <div class="aspect-video bg-slate-100 relative overflow-hidden">
                                {project.thumbnail ? (
                                    <EditorialImage
                                        src={project.thumbnail}
                                        alt={project.name}
                                        class="w-full h-full"
                                    />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center text-slate-400">
                                        Imagen no disponible
                                    </div>
                                )}
                            </div>
                            <div class="p-6 flex-1 flex flex-col">
                                <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">
                                    {project.name}
                                </h3>
                                <div class="text-slate-600 mb-6 flex-1 [&_p]:m-0">
                                    <Content />
                                </div>
                                <div class="flex flex-wrap gap-2 mt-auto">
                                    {project.technologies.map(
                                        (tech: string) => (
                                            <span class="text-xs font-medium text-slate-600 bg-slate-100 px-2.5 py-1 rounded-md">
                                                {tech}
                                            </span>
                                        ),
                                    )}
                                </div>
                            </div>
                        </div>
                    </a>
                );
            })
        }
    </div>
</section>
