---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/D4/Hero.astro";
import Experience from "../components/D4/Experience.astro";
import Projects from "../components/D4/Projects.astro";
import { technologies, personalInfo } from "../data/portfolio";

const allTech = [
    ...technologies.languages,
    ...technologies.frameworks,
    ...technologies.infrastructure,
];
---

<Layout title="NEON NEXUS | Aníbal Fermandois">
    <div
        class="min-h-screen bg-slate-900 font-sans text-slate-100 selection:bg-cyan-500/30 selection:text-cyan-200 overflow-x-hidden"
    >
        <div
            class="fixed inset-0 pointer-events-none z-50 mix-blend-overlay opacity-10 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPgo8cmVjdCB3aWR0aD0iNCIgaGVpZ2h0PSI0IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiLz4KPC9zdmc+')]"
        >
        </div>

        <!-- Scanline overlay global -->
        <div
            class="fixed inset-0 pointer-events-none z-40 bg-[linear-gradient(transparent_50%,rgba(0,0,0,0.1)_50%)] bg-[length:100%_4px]"
        >
        </div>

        <!-- Header bar -->
        <div
            class="w-full bg-black border-b border-fuchsia-500 flex justify-between px-4 py-1 text-xs font-mono text-cyan-500 shadow-[0_0_10px_rgba(217,70,239,0.3)] relative z-20"
        >
            <span class="animate-pulse">SIS.ACTIVO</span>
            <span>RED_SEGURA / PUERTO:8080</span>
            <span class="hidden md:inline"
                >FECHA_HORA: {new Date().getFullYear()}</span
            >
        </div>

        <Hero />
        <Experience />
        <Projects />

        <!-- Technologies section -->
        <section
            class="py-24 bg-slate-950 border-y border-cyan-500/30 relative overflow-hidden"
        >
            <!-- Glow -->
            <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-fuchsia-600/10 blur-[100px] rounded-full pointer-events-none"
            >
            </div>

            <div class="max-w-6xl mx-auto px-6 relative z-10 text-center">
                <h2
                    class="text-3xl md:text-4xl font-black text-white uppercase tracking-widest mb-12 drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]"
                >
                    <span class="text-cyan-400">&lt;</span> Arsenal_Tecnológico <span
                        class="text-fuchsia-500">/&gt;</span
                    >
                </h2>

                <div class="flex flex-wrap justify-center gap-4">
                    {
                        allTech.map((tech) => (
                            <div class="inline-flex items-center gap-2 bg-slate-900 border border-slate-700 px-4 py-2 font-mono text-sm md:text-base text-cyan-100 hover:border-cyan-400 hover:shadow-[0_0_15px_rgba(34,211,238,0.4)] hover:text-cyan-300 transition-all cursor-crosshair transform hover:scale-105">
                                <img
                                    src={`https://cdn.simpleicons.org/${tech.icon}/67e8f9`}
                                    class="w-5 h-5"
                                    alt=""
                                />
                                {tech.name}
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer
            class="bg-black py-16 relative border-t-4 border-fuchsia-500 overflow-hidden text-center"
        >
            <div
                class="absolute inset-0 bg-[linear-gradient(transparent_95%,rgba(217,70,239,0.1)_100%),linear-gradient(90deg,transparent_95%,rgba(6,182,212,0.1)_100%)] bg-[length:20px_20px] opacity-30"
            >
            </div>

            <div class="max-w-4xl mx-auto px-6 relative z-10">
                <h2
                    class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-fuchsia-500 mb-8 uppercase tracking-widest"
                >
                    Transmitiendo_SEÑAL...
                </h2>

                <div class="flex justify-center gap-8 mb-12">
                    <a
                        href={`mailto:${personalInfo.contact}`}
                        class="text-cyan-400 font-mono border-b border-cyan-400/30 hover:border-cyan-400 pb-1 hover:text-white transition-colors uppercase tracking-widest text-lg drop-shadow-[0_0_5px_rgba(34,211,238,0.5)]"
                    >
                        [ ENLACE_COM ]
                    </a>
                    <a
                        href="/4"
                        class="text-fuchsia-400 font-mono border-b border-fuchsia-400/30 hover:border-fuchsia-400 pb-1 hover:text-white transition-colors uppercase tracking-widest text-lg drop-shadow-[0_0_5px_rgba(217,70,239,0.5)]"
                    >
                        [ RECARGAR ]
                    </a>
                </div>

                <div class="text-slate-600 font-mono text-xs">
                    FIN DE LÍNEA.
                </div>
            </div>
        </footer>
    </div>
</Layout>

<style>
    @keyframes scan {
        0% {
            top: -100%;
            opacity: 0;
        }
        10% {
            opacity: 1;
        }
        90% {
            opacity: 1;
        }
        100% {
            top: 200%;
            opacity: 0;
        }
    }
</style>
