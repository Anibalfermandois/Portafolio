---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/D5/Hero.astro";
import Experience from "../components/D5/Experience.astro";
import Projects from "../components/D5/Projects.astro";
import { technologies, personalInfo } from "../data/portfolio";

const allTech = [
    ...technologies.languages,
    ...technologies.frameworks,
    ...technologies.infrastructure,
];
---

<Layout title="Aníbal Fermandois — Portfolio">
    <div
        class="min-h-screen font-sans text-stone-800 selection:bg-rose-100 selection:text-rose-900 bg-[#fbfaf8] relative overflow-hidden"
    >
        <!-- Fine grainy noise overlay -->
        <div
            class="fixed inset-0 pointer-events-none z-50 opacity-[0.03] mix-blend-multiply bg-[url('data:image/svg+xml;base64,')]"
        >
        </div>

        <Hero />
        <Experience />
        <Projects />

        <!-- Technologies / Capabilities -->
        <section class="py-32 relative z-10 px-6 border-t border-stone-200/50">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-20">
                    <span
                        class="text-sm font-semibold tracking-[0.2em] text-stone-400 uppercase"
                        >Capacidades</span
                    >
                    <h2
                        class="text-4xl md:text-5xl font-serif text-stone-900 italic mt-4"
                    >
                        Repertorio Técnico
                    </h2>
                </div>

                <div
                    class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto"
                >
                    {
                        allTech.map((tech) => (
                            <div class="flex items-center gap-2 bg-white/40 backdrop-blur-md border border-white hover:bg-white hover:shadow-md transition-all duration-300 px-6 py-3 rounded-full text-stone-600 hover:text-stone-900 cursor-default">
                                <img
                                    src={`https://cdn.simpleicons.org/${tech.icon}/57534e`}
                                    class="w-4 h-4 md:w-5 md:h-5 opacity-70"
                                    alt=""
                                />
                                <span class="tracking-wide text-sm md:text-base font-light">
                                    {tech.name}
                                </span>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="py-32 relative z-10 px-6">
            <div class="max-w-4xl mx-auto text-center">
                <h2
                    class="text-6xl md:text-8xl font-serif text-stone-900 italic mb-12"
                >
                    Hablemos.
                </h2>

                <a
                    href={`mailto:${personalInfo.contact}`}
                    class="inline-block relative text-2xl md:text-3xl text-stone-800 hover:text-amber-800 transition-colors duration-500 group"
                >
                    {personalInfo.contact}
                    <div
                        class="absolute -bottom-2 left-0 w-full h-[1px] bg-stone-300 origin-right transition-transform duration-500 scale-x-100 group-hover:scale-x-0"
                    >
                    </div>
                    <div
                        class="absolute -bottom-2 left-0 w-full h-[1px] bg-amber-800 origin-left transition-transform duration-500 scale-x-0 group-hover:scale-x-100 delay-100"
                    >
                    </div>
                </a>

                <div
                    class="mt-32 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-stone-400 tracking-wider"
                >
                    <div class="uppercase">© {new Date().getFullYear()}</div>
                    <div class="flex gap-8">
                        <a
                            href="/5"
                            class="hover:text-stone-800 transition-colors uppercase"
                            >Subir</a
                        >
                    </div>
                </div>
            </div>
        </footer>
    </div>
</Layout>
