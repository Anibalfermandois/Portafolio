---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/D1/Hero.astro";
import Experience from "../components/D1/Experience.astro";
import Projects from "../components/D1/Projects.astro";
import { personalInfo, technologies } from "../data/portfolio";
---

<Layout title="Aníbal Fermandois - Porfolio (Corporate)">
    <div
        class="min-h-screen bg-white font-sans text-slate-900 selection:bg-blue-100 selection:text-blue-900"
    >
        <Hero />
        <Experience />
        <Projects />

        <!-- Technologies -->
        <section class="bg-slate-50 py-12 px-6 border-t border-slate-100">
            <div
                class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-8 justify-between"
            >
                <div
                    class="text-sm font-bold text-slate-400 uppercase tracking-widest"
                >
                    Tecnologías Principales
                </div>
                <div
                    class="flex flex-wrap justify-center gap-4 text-sm text-slate-500"
                >
                    {
                        [
                            ...technologies.languages,
                            ...technologies.frameworks,
                            ...technologies.infrastructure,
                        ]
                            .slice(0, 10)
                            .map((tech) => (
                                <span class="hover:text-blue-600 transition-colors cursor-default flex items-center gap-2">
                                    <img
                                        src={`https://cdn.simpleicons.org/${tech.icon}/64748b`}
                                        class="w-4 h-4 opacity-70"
                                        alt=""
                                    />
                                    {tech.name}
                                </span>
                            ))
                    }
                    <span class="text-slate-400">y más...</span>
                </div>
            </div>
        </section>

        <!-- Contact & Footer -->
        <footer class="bg-slate-900 text-slate-400 py-12 px-6">
            <div
                class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6"
            >
                <div>
                    <h2 class="text-white text-xl font-bold mb-2">
                        Conectémonos
                    </h2>
                    <p class="text-sm">Disponible para nuevas oportunidades.</p>
                </div>
                <div class="flex items-center gap-4">
                    <a
                        href={`mailto:${personalInfo.contact}`}
                        class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors"
                    >
                        Escríbeme
                    </a>
                    <a
                        href="/1"
                        class="text-slate-300 hover:text-white text-sm font-medium transition-colors"
                    >
                        Enlace al Portafolio
                    </a>
                </div>
            </div>
        </footer>
    </div>
</Layout>
