---
import Layout from "../layouts/Layout.astro";

const variations = [
	{ id: 1, name: "Variación de Diseño 1" },
	{ id: 2, name: "Variación de Diseño 2" },
	{ id: 3, name: "Variación de Diseño 3" },
	{ id: 4, name: "Variación de Diseño 4" },
	{ id: 5, name: "Variación de Diseño 5" },
];
---

<Layout title="Prototipos de Portafolio">
	<main
		class="min-h-screen bg-neutral-50 flex items-center justify-center p-6 antialiased"
	>
		<div class="max-w-md w-full space-y-8">
			<div>
				<h1 class="text-2xl font-light text-neutral-900 tracking-tight">
					Prototipos
				</h1>
				<p class="text-sm text-neutral-500 mt-2 font-medium">
					Selecciona una iteración de diseño
				</p>
			</div>

			<nav class="flex flex-col gap-3">
				{
					variations.map((v) => (
						<a
							href={`/${v.id}`}
							class="group relative flex items-center justify-between p-4 rounded-2xl bg-white border border-neutral-200/60 text-neutral-600 hover:text-neutral-900 hover:border-neutral-300 hover:shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] transition-all duration-300 ease-out"
						>
							<span class="text-sm font-medium tracking-wide">
								{v.name}
							</span>
							<span class="text-neutral-400 group-hover:text-black opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="m18 15-6-6-6 6" />
								</svg>
							</span>
						</a>
					))
				}
			</nav>
		</div>
	</main>
</Layout>
