---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import { technologies } from "../content/portfolio";
import { getEntry } from "astro:content";

const personalInfoEntry = await getEntry("personal", "info");
const personalInfo = personalInfoEntry!.data;
---

<Layout title="Aníbal Fermandois - Portafolio">
	<div
		class="min-h-screen bg-white font-geist text-slate-900 selection:bg-blue-100 selection:text-blue-900"
	>
		<Hero />
		<Experience />
		<Projects />

		<!-- Technologies Marquee -->
		<section class="bg-slate-50 py-16 px-6 border-t border-slate-100 overflow-hidden reveal">
			<div class="max-w-5xl mx-auto mb-8 text-center">
				<div class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-2">
					Stack Técnico
				</div>
				<h2 class="text-3xl font-black text-slate-900 mb-12 flex items-center gap-4">Herramientas que utilizo</h2>
			</div>
			
			<div class="relative flex overflow-x-hidden group">
				<div class="py-4 animate-marquee whitespace-nowrap flex items-center gap-12">
					{
						[
							...technologies.languages,
							...technologies.frameworks,
							...technologies.infrastructure,
						].map((tech) => (
							<div class="flex items-center gap-3 text-slate-400 grayscale hover:grayscale-0 hover:text-blue-600 transition-all duration-300 cursor-default px-4">
								<img
									src={`https://cdn.simpleicons.org/${tech.icon}/64748b`}
									class="w-6 h-6 opacity-70 group-hover:opacity-100 transition-opacity"
									alt=""
								/>
								<span class="text-lg font-medium">{tech.name}</span>
							</div>
						))
					}
				</div>
				<!-- Duplicate for infinite effect -->
				<div class="absolute top-0 py-4 animate-marquee2 whitespace-nowrap flex items-center gap-12" aria-hidden="true">
					{
						[
							...technologies.languages,
							...technologies.frameworks,
							...technologies.infrastructure,
						].map((tech) => (
							<div class="flex items-center gap-3 text-slate-400 grayscale hover:grayscale-0 hover:text-blue-600 transition-all duration-300 cursor-default px-4">
								<img
									src={`https://cdn.simpleicons.org/${tech.icon}/64748b`}
									class="w-6 h-6 opacity-70 group-hover:opacity-100 transition-opacity"
									alt=""
								/>
								<span class="text-lg font-medium">{tech.name}</span>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- Contact & Footer -->
		<footer class="bg-slate-900 text-slate-400 py-20 px-6 mt-12">
			<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
				<div class="reveal">
					<h2 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter">
						¿Listo para <span class="text-blue-400 italic">colaborar?</span>
					</h2>
					<p class="text-lg mb-6 text-slate-300">
						Actualmente enfocado en el desarrollo de software de alto rendimiento y soluciones en la nube.
					</p>
				</div>
				<div class="flex flex-col md:items-end gap-8 reveal reveal-stagger-1">
					<div class="flex items-center gap-6">
						<a
							href={personalInfo.linkedin}
							target="_blank"
							rel="noopener noreferrer"
							class="text-slate-400 hover:text-white transition-all transform hover:scale-110"
							aria-label="LinkedIn"
						>
							<svg class="w-8 h-8 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
						</a>
						<a
							href="https://github.com/afermandois"
							target="_blank"
							rel="noopener noreferrer"
							class="text-slate-400 hover:text-white transition-all transform hover:scale-110"
							aria-label="GitHub"
						>
							<svg class="w-8 h-8 fill-current" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
						</a>
					</div>
					<a
						href={`mailto:${personalInfo.contact}`}
						class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-4 rounded-xl text-lg font-bold transition-all shadow-lg hover:shadow-blue-500/25 transform hover:-translate-y-1"
					>
						Hablemos
					</a>
				</div>
			</div>
			<div class="max-w-5xl mx-auto pt-12 mt-12 border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-medium uppercase tracking-widest text-slate-600">
				<p>© {new Date().getFullYear()} Aníbal Fermandois</p>
			</div>
		</footer>
	</div>
</Layout>
