---
import { defaultLocale, getLocalePath, locales } from "../i18n/config";

const fallbackPath = getLocalePath(defaultLocale);
const localePaths = Object.fromEntries(
    locales.map((locale) => [locale, getLocalePath(locale)]),
);
---

<!DOCTYPE html>
<html lang={defaultLocale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="canonical" href={fallbackPath} />
        <title>Aníbal Fermandois - Portfolio</title>
    </head>
    <body>
        <a href={fallbackPath}>Continue to portfolio</a>
        <script
            is:inline
            define:vars={{ defaultLocale, fallbackPath, localePaths }}
        >
            const cookies = Object.fromEntries(
                document.cookie
                    .split(";")
                    .map((part) => part.trim().split("="))
                    .filter(([key, value]) => key && value)
                    .map(([key, value]) => [key, decodeURIComponent(value)]),
            );
            const preferredLocale = cookies.preferred_locale;
            const hasLocale = (locale) =>
                Object.prototype.hasOwnProperty.call(localePaths, locale);

            const browserLanguages =
                navigator.languages?.length > 0
                    ? navigator.languages
                    : [navigator.language];
            const browserLocale = browserLanguages.some((language) =>
                language.toLowerCase().startsWith("es"),
            )
                ? "es"
                : defaultLocale;

            const locale = hasLocale(preferredLocale)
                ? preferredLocale
                : browserLocale;

            window.location.replace(localePaths[locale] ?? fallbackPath);
        </script>
    </body>
</html>
